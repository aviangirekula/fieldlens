# Copy this file to ".env" and paste your key below.
# Get a key at https://aistudio.google.com/apikey
#
# IMPORTANT: this is read ONLY on the server (the Vite proxy in
# server/geminiProxy.ts). It has no VITE_ prefix, so it is never exposed to the
# browser or bundled into client code.
GEMINI_API_KEY=your-key-here
